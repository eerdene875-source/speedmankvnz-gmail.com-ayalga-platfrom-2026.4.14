# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EMAIL_USER: The email address to send notifications from.
EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS: The app password for the email account.
EMAIL_PASS="your-app-password"

# GOOGLE_CLIENT_ID: Your Google OAuth Client ID
GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET: Your Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI: Your Google OAuth Redirect URI (e.g. https://your-app.run.app/api/auth/google/callback)
GOOGLE_REDIRECT_URI=""
